# Auto detect text files and normalise line endings
* text=auto

# Python files always use LF
*.py text eol=lf
*.pyi text eol=lf

# Config / data files
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.ini text eol=lf

# Shell scripts
*.sh text eol=lf
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.zip binary
*.gz binary
*.tar binary

